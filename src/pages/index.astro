---
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import SocialCard from "../components/SocialCard.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import portrait from "../assets/images/portrait.jpg";
import Education from "../components/Education.astro";

import ChevronRight from "../assets/icons/chevron-right.svg";

import { socialCards } from "../data/socials";

const posts = await getCollection("posts");
---

<Layout title="Psychology Shitikz | Личный психолог">
  <main>
    <!-- Hero Section -->
    <section class="section">
      <div class="container">
        <div class="hero">
          <div class="hero-content">
            <p class="hero-tag">Практикующий психолог</p>
            <h1 class="hero-title">
              Ваш путь к внутреннему спокойствию и саморазвитию
            </h1>
            <div class="hero-description">
              <p>
                Меня зовут Олеся Климова, я практический психолог и консультант
                по методике PSY2.0. Помогаю людям находить и устранять глубинные
                причины эмоциональных и психосоматических проблем.
              </p>
              <br />
              <p>
                В своей работе использую современный подход, основанный на
                тесной взаимосвязи психики и тела. Ко мне обращаются с
                тревожностью, страхами, паническими атаками, эмоциональным
                выгоранием, сложностями в отношениях, психосоматическими
                симптомами, а также с вопросами самореализации и поиска
                внутренних ресурсов.
              </p>
              <br />
            </div>

            <a href="#contact" class="btn btn-primary"
              >Записаться на консультацию</a
            >
          </div>
          <div class="hero-image-container">
            <div class="hero-image-bg"></div>

            <Image
              src={portrait}
              alt="Портрет психолога Олеси Климовой"
              class="hero-image"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Education Section -->
    <!-- <section
      class="section"
      id="education"
      style="background: var(--surface-container-low);"
    >
      <div class="container">
        <h2>Образование и квалификация</h2>
        <div class="card-grid">
          {education.map((item) => <EducationCard {...item} />)}
        </div>
      </div>
    </section> -->

    <Education />

    <!-- Latest Posts Section -->
    <section class="section" id="posts">
      <div class="container">
        <div class="posts-header">
          <div>
            <h2>Последние публикации</h2>
            <p class="section-subtitle">
              Полезные материалы о ментальном здоровье
            </p>
          </div>
          <a href="/blog" class="blog-link">Все статьи <ChevronRight /></a>
        </div>

        <div class="blog-grid">
          {
            posts.map((post) => (
              <PostCard {...post.data} id={post.id} content={post.body} />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="section" id="contact">
      <div class="container">
        <div class="contact-container">
          <div class="contact-info">
            <h2>Связаться со мной</h2>
            <!-- <p class="hero-description">
              Оставьте заявку или воспользуйтесь социальными сетями для быстрой
              связи. Я помогу вам выбрать формат и время консультации.
            </p> -->

            <div class="social-contact-grid">
              {socialCards.map((card) => <SocialCard {...card} />)}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Section specific styles */
  .hero {
    display: grid;
    gap: var(--spacing-lg);
    align-items: center;
    padding-top: var(--spacing-xl);
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: calc(80px + var(--spacing-xl));
      grid-template-columns: 1.2fr 1fr;
      gap: var(--spacing-xl);
    }
  }

  .hero-tag {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary);
    margin-bottom: var(--spacing-sm);
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--spacing-md);
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--on-surface-variant);
    margin-bottom: var(--spacing-lg);
    max-width: 540px;
  }

  .hero-image-container {
    position: relative;
  }

  .hero-image {
    width: 100%;
    max-height: 743px;
    aspect-ratio: 4/5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 40px var(--shadow-color);
    border: 1px solid var(--outline-variant);
  }

  .hero-image-bg {
    position: absolute;
    inset: -20px;
    background: var(--primary);
    opacity: 0.05;
    filter: blur(40px);
    z-index: -1;
  }

  .section-subtitle {
    color: var(--on-surface-variant);
  }

  .posts-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--spacing-lg);
  }

  .blog-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  @media (min-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Contact Section */
  .contact-container {
    background: var(--surface-container-lowest);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    display: grid;
    gap: var(--spacing-xl);
    box-shadow: 0 10px 30px var(--shadow-color);
  }

  @media (min-width: 1024px) {
    .contact-container {
      /* grid-template-columns: 1fr 1fr; */
      padding: var(--spacing-xl);
    }
  }

  .contact-info h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-md);
  }

  .social-contact-grid {
    display: grid;
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  @media (min-width: 830px) {
    .social-contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Form */
  .contact-form {
    display: grid;
    gap: var(--spacing-md);
  }

  .form-group {
    display: grid;
    gap: 4px;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--on-surface-variant);
    margin-left: var(--spacing-xs);
  }

  .form-control {
    width: 100%;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-lg);
    background: var(--input-bg);
    border: 1px solid transparent;
    transition: var(--transition);
    color: var(--on-surface);
  }

  .form-control:focus {
    border-color: var(--primary);
    background: var(--surface-container-lowest);
  }

  .form-row {
    display: grid;
    gap: var(--spacing-md);
  }

  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-footer-tip {
    text-align: center;
    font-size: 0.75rem;
    color: var(--on-surface-variant);
  }
</style>
