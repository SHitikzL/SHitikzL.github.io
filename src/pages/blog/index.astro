---
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection, getEntry } from "astro:content";

const posts = await getCollection("posts");
const recentPosts = [...posts].sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
---

<Layout title="Статьи | Psychology Shitikz">
  <main>
    <section class="page-header">
      <div class="container">
        <h1>Все публикации</h1>
        <p class="section-subtitle">
          Полезные статьи о ментальном здоровье, отношениях и саморазвитии
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="card-grid">
          {
            recentPosts.map((post) => (
              <PostCard {...post.data} id={post.id} content={post.body} />
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-header {
    padding-top: calc(80px + var(--spacing-xl));
    padding-bottom: var(--spacing-lg);
    text-align: center;
  }

  .section-subtitle {
    color: var(--on-surface-variant);
    font-size: 1.125rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    margin-bottom: var(--spacing-sm);
  }
</style>
