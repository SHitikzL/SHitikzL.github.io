---
import { Image } from "astro:assets";

interface Props {
  id: string;
  cover?: Cover;
  coverAlt?: string;
  pubDate: Date;
  title: string;
  description?: string;
  horizontal?: boolean;
  content?: string;
}
interface Cover {
  src: string;
  width: number;
  height: number;
  format: "png" | "jpg" | "jpeg" | "tiff" | "webp" | "gif" | "svg" | "avif";
}

const {
  id,
  cover,
  coverAlt,
  pubDate,
  title,
  description,
  horizontal = false,
  content,
} = Astro.props;

// Извлекаем части даты по UTC, чтобы избежать сдвига часовых поясов
const day = String(pubDate.getUTCDate()).padStart(2, "0");
const month = String(pubDate.getUTCMonth() + 1).padStart(2, "0");
const year = pubDate.getUTCFullYear();

// Собираем строку в формате dd.mm.yyyy
const formattedDate = `${day}.${month}.${year}`;

// Формируем строку для атрибута datetime (YYYY-MM-DD)
const isoDate = `${year}-${month}-${day}`;
---

<article class={`blog-card ${horizontal ? "horizontal" : ""}`}>
  <div class="blog-card-img-side">
    {
      cover && coverAlt && (
        <Image src={cover} alt={coverAlt} class="card-image" />
      )
    }
    <!-- <img src={image} alt={title} class="card-image" /> -->
  </div>
  <div class="blog-card-content">
    <div>
      <!-- <span class="card-date">{new Date(pubDate).toLocaleDateString()}</span> -->
      <time class="card-date" datetime={isoDate}>
        {formattedDate}
      </time>
      <h3>{title}</h3>
      <!-- <p class="card-subtitle">{description}</p> -->
      <p class="card-subtitle">{content?.slice(0, 200)}...</p>
    </div>
    <a href={"/blog/" + id} class="blog-link">Читать далее</a>
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 10px 30px var(--shadow-color);
    transition: var(--transition);
  }

  .blog-card:hover {
    background: var(--surface-container-low);
  }

  .blog-card.horizontal {
    @media (min-width: 1024px) {
      flex-direction: row;
    }
  }

  .blog-card-img-side {
    width: 100%;
    overflow: hidden;
  }

  .horizontal .blog-card-img-side {
    @media (min-width: 1024px) {
      width: 40%;
    }
  }

  .card-image {
    width: 100%;
    height: 100%;
    /* min-height: 300px;
    max-height: 400px; */
    object-fit: cover;
    transition: var(--transition);
  }

  .blog-card:hover .card-image {
    transform: scale(1.05);
  }

  .blog-card-content {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--spacing-md);
  }

  .horizontal .blog-card-content {
    @media (min-width: 1024px) {
      width: 60%;
    }
  }

  h3 {
    margin: var(--spacing-xs) 0;
    transition: var(--transition);
    color: var(--on-surface);
  }

  .blog-card:hover h3 {
    color: var(--primary);
  }

  .card-date {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary);
  }

  .card-subtitle {
    color: var(--on-surface-variant);
  }

  .blog-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
  }

  .blog-link span {
    font-size: 14px;
  }
</style>
