---
interface Props {
    image: string;
    date: string;
    title: string;
    description: string;
    href: string;
    horizontal?: boolean;
}

const { image, date, title, description, href, horizontal = false } = Astro.props;
---
<article class={`blog-card ${horizontal ? 'horizontal' : ''}`}>
    <div class="blog-card-img-side">
        <img src={image} alt={title} class="card-image">
    </div>
    <div class="blog-card-content">
        <div>
            <span class="card-date">{date}</span>
            <h3>{title}</h3>
            <p class="card-subtitle">{description}</p>
        </div>
        <a href={href} class="blog-link">Читать далее <span class="material-icons">open_in_new</span></a>
    </div>
</article>

<style>
    .blog-card {
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--outline-variant);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 10px 30px var(--shadow-color);
        transition: var(--transition);
    }

    .blog-card:hover {
        background: var(--surface-container-low);
    }

    .blog-card.horizontal {
        @media (min-width: 1024px) {
            flex-direction: row;
        }
    }

    .blog-card-img-side {
        width: 100%;
        overflow: hidden;
    }

    .horizontal .blog-card-img-side {
        @media (min-width: 1024px) {
            width: 40%;
        }
    }

    .card-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition);
    }

    .blog-card:hover .card-image {
        transform: scale(1.05);
    }

    .blog-card-content {
        padding: var(--spacing-lg);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: var(--spacing-md);
    }

    .horizontal .blog-card-content {
        @media (min-width: 1024px) {
            width: 60%;
        }
    }

    h3 {
        margin: var(--spacing-xs) 0;
        transition: var(--transition);
        color: var(--on-surface);
    }

    .blog-card:hover h3 {
        color: var(--primary);
    }

    .card-date {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--primary);
    }

    .card-subtitle {
        color: var(--on-surface-variant);
    }

    .blog-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-weight: 600;
        color: var(--primary);
        text-decoration: none;
    }

    .blog-link span {
        font-size: 14px;
    }
</style>
