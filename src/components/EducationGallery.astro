  /* ... */

  .education-gallery {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 1rem;
  }

  .gallery-item {
    height: 340px;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .education-gallery {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-item {
      height: 440px;
    }

    .gallery-item--wide {
      grid-column: span 2;
    }
  }

  /* @media (max-width: 640px) { */

  @media (max-width: 500px) {
    .education-gallery {
      grid-template-columns: 1fr;
    }

    .gallery-item {
      grid-column: auto;
      height: 440px;
    }
    .gallery-item--wide {
      grid-column: auto;
      height: 240px;
    }
  }
</style>
