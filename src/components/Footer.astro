---
---
<footer class="footer">
    <div class="container footer-grid">
        <div class="footer-column">
            <div class="logo">
                <span class="material-icons">spa</span>
                <span>Calm Psychology Violet</span>
            </div>
            <p class="footer-copy">© 2024 Calm Psychology Violet. A sanctuary for mental wellness.</p>
        </div>
        <div class="footer-column">
            <h4>Навигация</h4>
            <a href="/" class="footer-link">Главная</a>
            <a href="/#education" class="footer-link">Образование</a>
            <a href="/blog" class="footer-link">Публикации</a>
        </div>
        <div class="footer-column">
            <h4>Услуги</h4>
            <a href="#" class="footer-link">Индивидуальная терапия</a>
            <a href="#" class="footer-link">Семейная консультация</a>
            <a href="#" class="footer-link">Групповые занятия</a>
        </div>
        <div class="footer-column">
            <h4>Документы</h4>
            <a href="#" class="footer-link">Privacy Policy</a>
            <a href="#" class="footer-link">Terms of Service</a>
            <a href="#" class="footer-link">Book Consultation</a>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: var(--surface-container-lowest);
        padding: var(--spacing-xl) 0;
        border-top: 1px solid var(--outline-variant);
    }

    .footer-grid {
        display: grid;
        gap: var(--spacing-lg);
    }

    @media (min-width: 768px) {
        .footer-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .footer-grid {
            grid-template-columns: 1.5fr 1fr 1fr 1fr;
        }
    }

    .logo {
        display: flex;
        align-items: center;
        gap: var(--spacing-xs);
        font-family: 'Manrope', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        color: var(--primary);
        margin-bottom: var(--spacing-sm);
    }

    .footer-copy {
        color: var(--on-surface-variant);
        font-size: 1rem;
        opacity: 0.8;
    }

    .footer-column h4 {
        color: var(--primary);
        margin-bottom: var(--spacing-md);
        font-size: 1.25rem;
    }

    .footer-link {
        display: block;
        color: var(--on-surface-variant);
        margin-bottom: var(--spacing-xs);
        transition: var(--transition);
    }

    .footer-link:hover {
        color: var(--primary);
        transform: translateX(4px);
    }
</style>
