---
import PlantIcon from "../assets/icons/plant-2.svg";

import { socialCards } from "../data/socials";
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-column">
      <div class="logo">
        <PlantIcon />
        <span>Psychology Shitikz</span>
      </div>
      <p class="footer-copy">
        © 2026 Psychology Shitikz. A sanctuary for mental wellness.
      </p>
    </div>

    <div class="footer-column">
      <h4>Навигация</h4>
      <a href="/" class="footer-link">Главная</a>
      <a href="/#education" class="footer-link">Образование</a>
      <a href="/blog" class="footer-link">Публикации</a>
    </div>

    <div class="footer-column">
      <h4>Контакты</h4>
      {
        socialCards.map((card) => {
          const isExternal = card.href.startsWith("http");
          return (
            <a
              href={card.href}
              class="footer-link social-link"
              {...(isExternal
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
            >
              <card.icon class="social-icon" aria-hidden="true" />
              <span class="social-text">
                <span class="social-title">{card.title}</span>
                <span class="social-login">{card.login}</span>
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface-container-lowest);
    padding: var(--spacing-xl) 0;
    border-top: 1px solid var(--outline-variant);
  }

  .footer-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-family: var(--font-manrope), sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--primary);
    margin-bottom: var(--spacing-sm);
  }

  .footer-copy {
    color: var(--on-surface-variant);
    font-size: 1rem;
    opacity: 0.8;
  }

  .footer-column h4 {
    color: var(--primary);
    margin-bottom: var(--spacing-md);
    font-size: 1.25rem;
  }

  .footer-link {
    display: block;
    color: var(--on-surface-variant);
    margin-bottom: var(--spacing-xs);
    transition: var(--transition);
  }

  .footer-link:hover {
    color: var(--primary);
    transform: translateX(4px);
  }

  /* ===== Контакты: карточки соцсетей ===== */
  .social-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs) 0;
  }

  .social-link:hover {
    transform: translateX(4px);
  }

  .social-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    color: var(--primary);
    transition: var(--transition);
  }

  .social-link:hover .social-icon {
    color: var(--on-surface-variant);
  }

  .social-text {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .social-title {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .social-login {
    font-size: 0.85rem;
    opacity: 0.75;
  }
</style>
