---
interface Props {
  youtubeUrl?: string;
  vkUrl?: string;
  b17Url?: string;
}

const { youtubeUrl, vkUrl, b17Url } = Astro.props;

const tabs = [
  youtubeUrl && {
    id: "youtube",
    title: "YouTube",
    url: youtubeUrl,
  },
  vkUrl && {
    id: "vk",
    title: "VK Video",
    url: vkUrl,
  },
  b17Url && {
    id: "b17",
    title: "B17 Video",
    url: b17Url,
  },
].filter(Boolean);

const activeTab = tabs[0]?.id;
---

{
  (tabs.length > 1 && (
    <div class="video-tabs">
      <div class="video-tabs__header">
        {tabs.map((tab) => (
          <button
            class:list={[
              "video-tabs__button",
              tab.id === activeTab && "active",
            ]}
            data-tab={tab.id}
            type="button"
          >
            {tab.title}
          </button>
        ))}
      </div>

      {tabs.map((tab) => (
        <div
          class:list={["video-pane", tab.id === activeTab && "active"]}
          data-pane={tab.id}
        >
          <div class="video-wrapper">
            <iframe
              src={tab.url}
              allowfullscreen
              loading="lazy"
              referrerpolicy="strict-origin-when-cross-origin"
            />
          </div>
        </div>
      ))}
    </div>
  )) ||
    (tabs.length == 1 && (
      <div class="video-tabs">

        {tabs.map((tab) => (
          <div
            class:list={["video-pane", tab.id === activeTab && "active"]}
            data-pane={tab.id}
          >
            <div class="video-wrapper">
              <iframe
                src={tab.url}
                allowfullscreen
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
              />
            </div>
          </div>
        ))}
      </div>
    ))
}

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".video-tabs").forEach((tabsRoot) => {
      const buttons = tabsRoot.querySelectorAll(".video-tabs__button");

      const panes = tabsRoot.querySelectorAll(".video-pane");

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const tab = button.getAttribute("data-tab");

          buttons.forEach((btn) => btn.classList.remove("active"));

          panes.forEach((pane) => pane.classList.remove("active"));

          button.classList.add("active");

          tabsRoot
            .querySelector(`.video-pane[data-pane="${tab}"]`)
            ?.classList.add("active");
        });
      });
    });
  });
</script>

<style>
  .video-pane {
    display: none;
  }

  .video-pane.active {
    display: block;
  }

  .video-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .video-wrapper iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-tabs {
    margin: 2rem 0;
  }

  .video-tabs__header {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .video-tabs__button {
    border: 1px solid var(--outline-variant);
    background: var(--surface-container-low);
    color: var(--on-surface);
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: 0.2s;
  }

  .video-tabs__button.active {
    background: var(--primary);
    color: var(--on-primary);
  }
</style>
