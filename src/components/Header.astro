---
---
<header class="header">
    <div class="container">
        <a href="/" class="logo">
            <span class="material-icons">spa</span>
            <span>Calm Psychology Violet</span>
        </a>
        <nav class="nav">
            <a href="/" class="nav-link">Главная</a>
            <a href="/#education" class="nav-link">Образование</a>
            <a href="/blog" class="nav-link">Статьи</a>
            <a href="/#contact" class="nav-link">Контакты</a>
        </nav>
        <div class="header-actions">
            <button class="icon-btn" id="theme-toggle" aria-label="Toggle theme">
                <span class="material-icons" id="theme-icon">dark_mode</span>
            </button>
            <button class="icon-btn md-only" aria-label="Menu">
                <span class="material-icons">menu</span>
            </button>
        </div>
    </div>
</header>

<style>
    .header {
        position: fixed;
        top: 0;
        width: 100%;
        height: 80px;
        z-index: 1000;
        background: rgba(var(--surface), 0.8);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--outline-variant);
        display: flex;
        align-items: center;
    }

    .header .container {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: var(--spacing-xs);
        font-family: 'Manrope', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        color: var(--primary);
    }

    .nav {
        display: none;
    }

    @media (min-width: 768px) {
        .nav {
            display: flex;
            gap: var(--spacing-lg);
        }
    }

    .nav-link {
        color: var(--on-surface-variant);
        font-weight: 500;
        padding: 4px 0;
        border-bottom: 2px solid transparent;
        transition: var(--transition);
    }

    .nav-link:hover {
        color: var(--primary);
        border-bottom-color: var(--primary);
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .icon-btn {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        color: var(--on-surface-variant);
        cursor: pointer;
        transition: var(--transition);
    }

    .icon-btn:hover {
        background: var(--surface-container-low);
    }

    @media (min-width: 768px) {
        .md-only {
            display: none;
        }
    }
</style>
