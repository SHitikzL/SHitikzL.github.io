---
import DarkModeIcon from "../assets/icons/moon.svg";
import LightModeIcon from "../assets/icons/brightness-up.svg";
import MenuIcon from "../assets/icons/menu-2.svg";
import PlantIcon from "../assets/icons/plant-2.svg";
---

<header class="header">
  <div class="container">
    <a href="/" class="logo">
      <PlantIcon />
      <span>Psychology Shitikz</span>
    </a>
    <nav class="nav">
      <a href="/" class="nav-link">Главная</a>
      <a href="/#education" class="nav-link">Образование</a>
      <a href="/blog" class="nav-link">Статьи</a>
      <a href="/#contact" class="nav-link">Контакты</a>
    </nav>
    <div class="header-actions">
      <button class="icon-btn" id="theme-toggle" aria-label="Toggle theme">
        <span class="icon-wrapper icon-dark">
          <DarkModeIcon class="theme-icon" />
        </span>
        <span class="icon-wrapper icon-light">
          <LightModeIcon class="theme-icon" />
        </span>
      </button>
      <button class="icon-btn md-only" aria-label="Menu">
        <MenuIcon />
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    width: 100%;
    height: 80px;
    z-index: 1000;
    background: rgba(var(--surface), 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--outline-variant);
    display: flex;
    align-items: center;
  }

  .header .container {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-family: var(--font-manrope), sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--primary);
  }

  .nav {
    display: none;
  }

  @media (min-width: 768px) {
    .nav {
      display: flex;
      gap: var(--spacing-lg);
    }
  }

  .nav-link {
    color: var(--on-surface-variant);
    font-weight: 500;
    padding: 4px 0;
    border-bottom: 2px solid transparent;
    transition: var(--transition);
  }

  .nav-link:hover {
    color: var(--primary);
    border-bottom-color: var(--primary);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .icon-btn {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--on-surface-variant);
    cursor: pointer;
    transition: var(--transition);
  }

  .icon-btn:hover {
    background: var(--surface-container-low);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-icon {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  .icon-dark {
    display: none;
  }

  .icon-light {
    display: flex;
  }

  :global([data-theme="dark"]) .icon-dark {
    display: flex;
  }

  :global([data-theme="dark"]) .icon-light {
    display: none;
  }

  @media (min-width: 768px) {
    .md-only {
      display: none;
    }
  }
</style>
