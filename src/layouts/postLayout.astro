---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import ChevronLeft from "../assets/icons/chevron-left.svg";

interface Props {
  id: string;
  cover?: Cover;
  coverAlt?: string;
  pubDate: Date;
  title: string;
  description?: string;
  horizontal?: boolean;
}
interface Cover {
  src: string;
  width: number;
  height: number;
  format: "png" | "jpg" | "jpeg" | "tiff" | "webp" | "gif" | "svg" | "avif";
}

const {
  id,
  cover,
  coverAlt,
  pubDate,
  title,
  description,
  horizontal = false,
} = Astro.props;

// Извлекаем части даты по UTC, чтобы избежать сдвига часовых поясов
const day = String(pubDate.getUTCDate()).padStart(2, "0");
const month = String(pubDate.getUTCMonth() + 1).padStart(2, "0");
const year = pubDate.getUTCFullYear();

// Собираем строку в формате dd.mm.yyyy
const formattedDate = `${day}.${month}.${year}`;

// Формируем строку для атрибута datetime (YYYY-MM-DD)
const isoDate = `${year}-${month}-${day}`;
---

<Layout title={title}>
  <main>
    <article class="section">
      <div class="container post-content">
        <header class="post-header">
          <div class="post-meta">
            <!-- <span>{new Date(pubDate).toLocaleDateString()}</span> -->
            <time class="card-date" datetime={isoDate}>
              {formattedDate}
            </time>
            <!-- <span>•</span>
            <span>tag???</span> -->
          </div>
          <h1>{title}</h1>
        </header>

        {
          cover && coverAlt && (
            <Image
              src={cover}
              alt={coverAlt}
              class="post-hero-image"
              layout="constrained"
              width={752}
            />
          )
        }

        <!-- <img src={image} alt="Тревога в городе" class="post-hero-image" /> -->
        <div class="article-body">
          <slot />
        </div>

        <footer class="post-footer">
          <a href="/blog" class="blog-link"><ChevronLeft /> Назад к статьям</a>
        </footer>
      </div>
    </article>
  </main>
</Layout>

<style>
  .section {
    padding-top: calc(80px + var(--spacing-xl));
  }

  .post-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .post-header {
    text-align: left;
    margin-bottom: var(--spacing-lg);
  }

  .post-meta {
    display: flex;
    gap: var(--spacing-md);
    color: var(--primary);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    margin-bottom: var(--spacing-sm);
    color: var(--on-surface);
  }

  .post-hero-image {
    width: 100%;
    /* max-width: 752px; */
    min-height: 423px;
    max-height: 423px;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: var(--spacing-xl);
  }

  .article-body :global(h2) {
    margin: var(--spacing-lg) 0 var(--spacing-sm);
    color: var(--on-surface);
  }

  .article-body :global(p) {
    margin-bottom: var(--spacing-md);
    font-size: 1.125rem;
    color: var(--on-surface-variant);
    line-height: 1.8;
  }

  .article-body :global(ol) {
    margin-left: 20px;
    margin-bottom: var(--spacing-md);
    color: var(--on-surface-variant);
  }

  .article-body :global(li) {
    margin-bottom: 10px;
  }

  .post-footer {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--outline-variant);
  }

  .blog-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
    transition: var(--transition);
  }

  .blog-link:hover {
    transform: translateX(-4px);
  }
</style>
