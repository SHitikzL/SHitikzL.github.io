{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "showDescription": {
      "default": true,
      "type": "boolean"
    },
    "cover": {
      "type": "string"
    },
    "coverAlt": {
      "type": "string"
    },
    "coverInPost": {
      "type": "boolean"
    },
    "horizontal": {
      "default": false,
      "type": "boolean"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "video": {
      "type": "object",
      "properties": {
        "youtube": {
          "type": "string"
        },
        "vk": {
          "type": "string"
        },
        "b17": {
          "type": "string"
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "pubDate"
  ]
}